---
import * as interfaces from "@/lib/interfaces";
import { filePath } from "@/lib/blog-helpers";
import Icon from "@/components/Icon.astro";
import { ENABLE_LIGHTBOX } from "@/constants";
import Caption from "@/components/notion-blocks/Caption.astro";

export interface Props {
	block: interfaces.Block;
	setId?: boolean;
}

const { block, setId = true } = Astro.props;

let url: URL;
try {
	url = new URL(block.File?.External?.Url || block.File?.File?.Url);
} catch (err) {
	console.error(`Invalid file URL. error: ${err}`);
}
const filename = decodeURIComponent(url.pathname.split("/").slice(-1)[0]);
const plainTextCaption = block.File?.Caption.map((richText) => richText.PlainText).join("");
---

<div class="file" id={setId ? block.Id : undefined}>
	{
		url && (
			<div>
                {block.File.Caption && block.File.Caption.length > 0 ? (
                    <Caption richTexts={block.File.Caption} block={block} footnotes={block.Footnotes} />
                ) : (
                    <span>{filename}</span>
                )}
				{"  "}
				<span class="border-accent-2/20 hover:border-accent/40 inline-flex max-w-full rounded-lg border p-1">
					<a
						href={block.File.External ? url.href : filePath(url)}
						target="_blank"
						rel="noopener noreferrer"
					>
						<span class="site-page-link text-link inline-flex max-w-full items-center justify-center rounded-lg text-sm">
							Download{" "}
							<Icon name={"download"} class="inline h-4 w-4 align-sub" aria-hidden="true" />
						</span>
					</a>
					{/* Conditional Preview for PDFs */}
					{filename.endsWith(".pdf") && ENABLE_LIGHTBOX && (
						<a
							href={block.File.External ? url.href : filePath(url)}
							class="fileglightbox hidden sm:inline"
							type="application/pdf"
						>
							<span class="decoration-accent-2/20 hover:decoration-accent/40 ml-2 inline-flex max-w-full items-center justify-center text-sm underline decoration-wavy">
								Preview{" "}
								<Icon name={"preview-pdf"} class="inline h-4 w-4 align-sub" aria-hidden="true" />
							</span>
						</a>
					)}
				</span>
			</div>
		)
	}
</div>
